{
  "name": "codventure",
  "displayName": "Codventure",
  "description": "Code to grow a pixel monster — your companion evolves as you save files and code.",
  "version": "1.0.0",
  "publisher": "uwol-is-june",
  "repository": {
    "type": "git",
    "url": "https://github.com/uwol-is-june/codventure.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "icon.png",
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "codventure",
          "name": "Codventure"
        }
      ]
    },
    "commands": [],
    "configuration": {
      "title": "Codventure",
      "properties": {
        "codventure.sound": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "사운드 효과 on/off (레벨업·진화·XP 획득 시 8비트 효과음)"
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0"
  }
}
